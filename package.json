    "jsdom": "^24.1.0",
    "next-test-api-route-handler": "^4.0.16",
    "postcss": "^8.5.10",
    "prisma": "^5.16.0",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^6.3.0",
