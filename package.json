    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@prisma/client": "^5.16.0",
    "@react-three/drei": "^10.7.7",
