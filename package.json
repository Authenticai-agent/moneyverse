{
  "name": "moneyverse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:static": "npx tailwindcss -i app/globals.css -o dist/index.css",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
